.ym-picker-wrap.data-v-7bedd8d5 {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
}

/* 顶部按钮条 */
.ym-picker-bar.data-v-7bedd8d5 {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 10rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  -webkit-backdrop-filter: blur(8rpx);
          backdrop-filter: blur(8rpx);
  transition: background 0.2s;
}
.ym-picker-bar.data-v-7bedd8d5:active {
  background: rgba(255, 255, 255, 0.3);
}
.ym-picker-nav.data-v-7bedd8d5 {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  transition: background 0.15s;
  flex-shrink: 0;
}
.ym-picker-nav.data-v-7bedd8d5:active {
  background: rgba(255, 255, 255, 0.3);
}
.ym-picker-arrow.data-v-7bedd8d5 {
  font-size: 44rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}
.ym-picker-center.data-v-7bedd8d5 {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}
.ym-picker-label.data-v-7bedd8d5 {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}
.ym-picker-chevron.data-v-7bedd8d5 {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 下拉面板 */
.ym-picker-panel.data-v-7bedd8d5 {
  position: absolute;
  top: calc(100% + 12rpx);
  left: 50%;
  transform: translateX(-50%);
  z-index: 999;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 20rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
  width: 400rpx;
  overflow: hidden;
  animation: ymFadeIn-7bedd8d5 0.2s ease;
}
@keyframes ymFadeIn-7bedd8d5 {
from { opacity: 0; transform: translateX(-50%) translateY(-12rpx);
}
to { opacity: 1; transform: translateX(-50%) translateY(0);
}
}

/* 年份行 */
.ym-picker-year-row.data-v-7bedd8d5 {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 0 0 16rpx;
  border-bottom: 1rpx solid #F1F5F9;
  margin-bottom: 16rpx;
}
.ym-picker-year-nav.data-v-7bedd8d5 {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F1F5F9;
  transition: background 0.15s;
  flex-shrink: 0;
}
.ym-picker-year-nav.data-v-7bedd8d5:active {
  background: #E2E8F0;
}
.ym-picker-year-arrow.data-v-7bedd8d5 {
  font-size: 28rpx;
  color: #64748B;
  font-weight: bold;
  line-height: 1;
}
.ym-picker-year-text.data-v-7bedd8d5 {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 600;
  flex: 1;
  text-align: center;
}

/* 月份网格 */
.ym-picker-grid.data-v-7bedd8d5 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}
.ym-picker-cell.data-v-7bedd8d5 {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  border-radius: 16rpx;
  background: #F1F5F9;
  transition: all 0.15s;
}
.ym-picker-cell.data-v-7bedd8d5:active {
  transform: scale(0.95);
}
.ym-picker-cell-text.data-v-7bedd8d5 {
  font-size: 24rpx;
  color: #475569;
}
.ym-picker-cell-active.data-v-7bedd8d5 {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%);
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.3);
}
.ym-picker-cell-active .ym-picker-cell-text.data-v-7bedd8d5 {
  color: #fff;
  font-weight: 600;
}

/* 遮罩 */
.ym-picker-mask.data-v-7bedd8d5 {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 998;
}